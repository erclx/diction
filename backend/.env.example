# Run mode: 'user' persists the DB, 'dev' resets an empty one each boot
DICTION_RUN_MODE=user

# Serve canned model output instead of loading the real stacks
DICTION_USE_STUB_SCORER=true
DICTION_USE_STUB_EXPLAINER=true
DICTION_USE_STUB_CRITIC=true
DICTION_USE_STUB_SYNTH=true

# Free-topic critic model, defaults to DICTION_LLM_MODEL_ID
# DICTION_CRITIC_MODEL_ID=gemma2:9b

# Kokoro reference voice (af_heart default, am_michael alt)
DICTION_TTS_VOICE=af_heart
