# Run mode selects the database and recordings location.
# 'user' keeps a persistent DB under backend/data; 'dev' resets an empty
# scratch DB under backend/.dev-data on every boot. dev.sh and CI set 'dev'.
DICTION_RUN_MODE=user

DICTION_USE_STUB_SCORER=true
DICTION_USE_STUB_EXPLAINER=true
DICTION_USE_STUB_SYNTH=true
